apiVersion: apps/v1
kind: Deployment
metadata:
  name: orderservice-deployment
  labels:
    app: orderservice
spec:
  replicas: 1
  selector:
    matchLabels:
      app: orderservice
  template:
    metadata:
      labels:
        app: orderservice
    spec:
      containers:
        - name: orderservice
          image: microservices/orderservice:latest
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8080
          env:
            - name: ASPNETCORE_ENVIRONMENT
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: ASPNETCORE_ENVIRONMENT
            - name: ASPNETCORE_URLS
              value: "http://+:8080"
            - name: SA_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: sqldata-secret
                  key: sa-password
            - name: OrderConnection
              value: "Server=sqldata-clusterip-srv,1433;Database=MicroserviceOrderDB;User Id=sa;Password=$(SA_PASSWORD);Encrypt=False;TrustServerCertificate=true;"
            - name: DatabaseSettings__ConnectionString
              value: "mongodb://admin:123321Aa%40@mongo-clusterip-srv:27017/?authSource=admin"
            - name: DatabaseSettings__DatabaseName
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: DatabaseSettings__DatabaseName
            - name: RabbitMq__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: RabbitMq__Uri
            - name: RabbitMq__HostName
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: RabbitMq__HostName
            - name: MicroServiceAddress__Product__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: MicroServiceAddress__Product__Uri
            - name: Identity__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: Identity__Uri
          readinessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 10
            failureThreshold: 10
          livenessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 60
            periodSeconds: 20
            failureThreshold: 5
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "500m"
---
apiVersion: v1
kind: Service
metadata:
  name: orderservice-clusterip-srv
spec:
  type: ClusterIP
  selector:
    app: orderservice
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: orderservice-nodeport-srv
spec:
  type: NodePort
  selector:
    app: orderservice
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
      nodePort: 31705
