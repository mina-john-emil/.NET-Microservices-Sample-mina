apiVersion: apps/v1
kind: Deployment
metadata:
  name: apigatewayforweb-deployment
  labels:
    app: apigatewayforweb
spec:
  replicas: 1
  selector:
    matchLabels:
      app: apigatewayforweb
  template:
    metadata:
      labels:
        app: apigatewayforweb
    spec:
      containers:
        - name: apigatewayforweb
          image: microservices/apigatewayforweb:latest
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 80
          env:
            # Must be Production so Ocelot loads Production/*.ocelot.Production.json
            # (the files with K8s ClusterIP host names)
            - name: ASPNETCORE_ENVIRONMENT
              value: "Production"
            - name: ASPNETCORE_URLS
              value: "http://+:80"
            - name: Identity__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: Identity__Uri
            - name: MicroserviceAddress__Discount__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: MicroServiceAddress__Discount__Uri
            - name: MicroserviceAddress__DiscountGrpc__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: MicroServiceAddress__DiscountGrpc__Uri
          readinessProbe:
            httpGet:
              path: /health
              port: 80
            initialDelaySeconds: 10
            periodSeconds: 10
            failureThreshold: 5
          livenessProbe:
            httpGet:
              path: /health
              port: 80
            initialDelaySeconds: 20
            periodSeconds: 20
            failureThreshold: 3
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "300m"
---
apiVersion: v1
kind: Service
metadata:
  name: apigatewayforweb-clusterip-srv
spec:
  type: ClusterIP
  selector:
    app: apigatewayforweb
  ports:
    - name: http
      protocol: TCP
      port: 80
      targetPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: apigatewayforweb-nodeport-srv
spec:
  type: NodePort
  selector:
    app: apigatewayforweb
  ports:
    - name: http
      protocol: TCP
      port: 80
      targetPort: 80
      nodePort: 30023
