apiVersion: apps/v1
kind: Deployment
metadata:
  name: apigatewayforweb-deployment
  labels:
    app: apigatewayforweb
spec:
  replicas: 1
  selector:
    matchLabels:
      app: apigatewayforweb
  template:
    metadata:
      labels:
        app: apigatewayforweb
    spec:
      containers:
        - name: apigatewayforweb
          image: microservices/apigatewayforweb:latest
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8080
          env:
            - name: ASPNETCORE_ENVIRONMENT
              value: "Production"
            - name: ASPNETCORE_URLS
              value: "http://+:8080"
            - name: Identity__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: Identity__Uri
            - name: MicroserviceAddress__Discount__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: MicroServiceAddress__Discount__Uri
            - name: MicroserviceAddress__DiscountGrpc__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: MicroServiceAddress__DiscountGrpc__Uri
          readinessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 20
            periodSeconds: 10
            failureThreshold: 10
          livenessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 40
            periodSeconds: 20
            failureThreshold: 5
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "300m"
---
apiVersion: v1
kind: Service
metadata:
  name: apigatewayforweb-clusterip-srv
spec:
  type: ClusterIP
  selector:
    app: apigatewayforweb
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: apigatewayforweb-nodeport-srv
spec:
  type: NodePort
  selector:
    app: apigatewayforweb
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
      nodePort: 30023
