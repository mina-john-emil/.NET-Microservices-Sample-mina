apiVersion: apps/v1
kind: Deployment
metadata:
  name: webfrontend-deployment
  labels:
    app: webfrontend
spec:
  replicas: 1
  selector:
    matchLabels:
      app: webfrontend
  template:
    metadata:
      labels:
        app: webfrontend
    spec:
      containers:
        - name: webfrontend
          image: microservices/microserviceswebfrontend:latest
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8080
          env:
            - name: ASPNETCORE_ENVIRONMENT
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: ASPNETCORE_ENVIRONMENT
            - name: ASPNETCORE_URLS
              value: "http://+:8080"
            - name: Identity__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: Identity__Uri
            - name: MicroserviceAddress__ApiGatewayForWeb__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: MicroserviceAddress__ApiGatewayForWeb__Uri
          readinessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 20
            periodSeconds: 10
            failureThreshold: 10
          livenessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 40
            periodSeconds: 20
            failureThreshold: 5
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "300m"
---
apiVersion: v1
kind: Service
metadata:
  name: webfrontend-clusterip-srv
spec:
  type: ClusterIP
  selector:
    app: webfrontend
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: webfrontend-nodeport-srv
spec:
  type: NodePort
  selector:
    app: webfrontend
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
      nodePort: 31443
