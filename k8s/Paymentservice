apiVersion: apps/v1
kind: Deployment
metadata:
  name: paymentservice-deployment
  labels:
    app: paymentservice
spec:
  replicas: 1
  selector:
    matchLabels:
      app: paymentservice
  template:
    metadata:
      labels:
        app: paymentservice
    spec:
      containers:
        - name: paymentservice
          image: microservices/paymentserviceendpoint:latest
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8080
          env:
            - name: ASPNETCORE_ENVIRONMENT
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: ASPNETCORE_ENVIRONMENT
            - name: ASPNETCORE_URLS
              value: "http://+:8080"
            - name: SA_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: sqldata-secret
                  key: sa-password
            - name: PaymentConnection
              value: "Server=sqldata-clusterip-srv,1433;Database=MicroservicePaymentDB;User Id=sa;Password=$(SA_PASSWORD);Encrypt=False;TrustServerCertificate=true;"
            - name: RabbitMq__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: RabbitMq__Uri
            - name: RabbitMq__HostName
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: RabbitMq__HostName
            - name: Identity__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: Identity__Uri
          readinessProbe:
            tcpSocket:
              port: 808080
            initialDelaySeconds: 30
            periodSeconds: 10
            failureThreshold: 10
          livenessProbe:
            tcpSocket:
              port: 808080
            initialDelaySeconds: 60
            periodSeconds: 20
            failureThreshold: 5
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "500m"
---
apiVersion: v1
kind: Service
metadata:
  name: paymentservice-clusterip-srv
spec:
  type: ClusterIP
  selector:
    app: paymentservice
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: paymentservice-nodeport-srv
spec:
  type: NodePort
  selector:
    app: paymentservice
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
      nodePort: 31104
