apiVersion: apps/v1
kind: Deployment
metadata:
  name: apigatewayadmin-deployment
  labels:
    app: apigatewayadmin
spec:
  replicas: 1
  selector:
    matchLabels:
      app: apigatewayadmin
  template:
    metadata:
      labels:
        app: apigatewayadmin
    spec:
      containers:
        - name: apigatewayadmin
          image: microservices/apigatewayadmin:latest
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 8080
          env:
            - name: ASPNETCORE_ENVIRONMENT
              value: "Production"
            - name: ASPNETCORE_URLS
              value: "http://+:8080"
            - name: Identity__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: Identity__Uri
          readinessProbe:
            tcpSocket:
              port: 808080
            initialDelaySeconds: 20
            periodSeconds: 10
            failureThreshold: 10
          livenessProbe:
            tcpSocket:
              port: 808080
            initialDelaySeconds: 40
            periodSeconds: 20
            failureThreshold: 5
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "300m"
---
apiVersion: v1
kind: Service
metadata:
  name: apigatewayadmin-clusterip-srv
spec:
  type: ClusterIP
  selector:
    app: apigatewayadmin
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: apigatewayadmin-nodeport-srv
spec:
  type: NodePort
  selector:
    app: apigatewayadmin
  ports:
    - name: http
      protocol: TCP
      port: 8080
      targetPort: 8080
      nodePort: 31023
