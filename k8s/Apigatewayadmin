apiVersion: apps/v1
kind: Deployment
metadata:
  name: apigatewayadmin-deployment
  labels:
    app: apigatewayadmin
spec:
  replicas: 1
  selector:
    matchLabels:
      app: apigatewayadmin
  template:
    metadata:
      labels:
        app: apigatewayadmin
    spec:
      containers:
        - name: apigatewayadmin
          image: microservices/apigatewayadmin:latest
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: 80
          env:
            # Must be Production so Ocelot loads ocelot.product.json
            # (the file with K8s ClusterIP host names)
            - name: ASPNETCORE_ENVIRONMENT
              value: "Production"
            - name: ASPNETCORE_URLS
              value: "http://+:80"
            - name: Identity__Uri
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: Identity__Uri
          readinessProbe:
            httpGet:
              path: /health
              port: 80
            initialDelaySeconds: 10
            periodSeconds: 10
            failureThreshold: 5
          livenessProbe:
            httpGet:
              path: /health
              port: 80
            initialDelaySeconds: 20
            periodSeconds: 20
            failureThreshold: 3
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "300m"
---
apiVersion: v1
kind: Service
metadata:
  name: apigatewayadmin-clusterip-srv
spec:
  type: ClusterIP
  selector:
    app: apigatewayadmin
  ports:
    - name: http
      protocol: TCP
      port: 80
      targetPort: 80
---
apiVersion: v1
kind: Service
metadata:
  name: apigatewayadmin-nodeport-srv
spec:
  type: NodePort
  selector:
    app: apigatewayadmin
  ports:
    - name: http
      protocol: TCP
      port: 80
      targetPort: 80
      nodePort: 31023
