apiVersion: apps/v1
kind: Deployment
metadata:
  name: discountservice-deployment
  labels:
    app: discountservice
spec:
  replicas: 1
  selector:
    matchLabels:
      app: discountservice
  template:
    metadata:
      labels:
        app: discountservice
    spec:
      containers:
        - name: discountservice
          image: microservices/discountservice:latest
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 80
            - name: grpc
              containerPort: 81
          env:
            - name: ASPNETCORE_ENVIRONMENT
              valueFrom:
                configMapKeyRef:
                  name: microservices-config
                  key: ASPNETCORE_ENVIRONMENT
            - name: SA_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: sqldata-secret
                  key: sa-password
            - name: DiscountConnection
              value: "Server=sqldata-clusterip-srv,1433;Database=MicroserviceDiscountDB;User Id=sa;Password=$(SA_PASSWORD);Encrypt=False;TrustServerCertificate=true;"
            # Kestrel dual-endpoint: port 80 for REST, port 81 for gRPC (HTTP/2)
            - name: Kestrel__Endpoints__HTTP__Url
              value: "http://+:80"
            - name: Kestrel__Endpoints__GRPC__Url
              value: "http://+:81"
            - name: Kestrel__Endpoints__GRPC__Protocols
              value: "Http2"
          readinessProbe:
            httpGet:
              path: /health
              port: 80
            initialDelaySeconds: 15
            periodSeconds: 10
            failureThreshold: 5
          livenessProbe:
            httpGet:
              path: /health
              port: 80
            initialDelaySeconds: 30
            periodSeconds: 20
            failureThreshold: 3
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "500m"
---
apiVersion: v1
kind: Service
metadata:
  name: discountservice-clusterip-srv
spec:
  type: ClusterIP
  selector:
    app: discountservice
  ports:
    - name: http
      protocol: TCP
      port: 80
      targetPort: 80
    - name: grpc
      protocol: TCP
      port: 81
      targetPort: 81
